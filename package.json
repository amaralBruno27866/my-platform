{
  "name": "my-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:infra": "docker compose up -d mongo redis",
    "down:infra": "docker compose down",
    "logs:infra": "docker compose logs -f mongo redis",
    "health:infra": "docker compose ps",
    "prepare:all": "npm install --workspaces --if-present",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run start -w apps/web",
    "build:api": "npm run build -w apps/api",
    "test:api": "npm run test -w apps/api",
    "test:api:watch": "npm run test:watch -w apps/api",
    "test:api:coverage": "npm run test:coverage -w apps/api",
    "test": "npm run test -w apps/api",
    "test:watch": "npm run test:watch -w apps/api",
    "test:coverage": "npm run test:coverage -w apps/api"
  }
}
